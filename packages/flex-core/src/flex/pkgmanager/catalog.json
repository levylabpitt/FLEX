{
  "flex-core": {
    "group": "Core",
    "summary": "Instrument model, data & metadata services, package manager, dashboard, CLI",
    "default": true,
    "provides": {
      "storage": ["local"]
    },
    "registries": {
      "storage": "flex.data:STORAGE"
    }
  },
  "flex-protocols": {
    "group": "Core",
    "summary": "Protocol instrument base classes: VISA, TCP, Serial, ZMQ",
    "default": true
  },
  "flex-db": {
    "group": "Core",
    "summary": "Metadata database backends: SQLite (default) and PostgreSQL",
    "default": true,
    "provides": {
      "db": ["sqlite", "postgres"]
    },
    "registries": {
      "db": "flex_db:DB_BACKENDS"
    }
  },
  "flex-exp": {
    "group": "Core",
    "summary": "Experiment handling: Experiment, Measurement, Scan, lab sessions",
    "default": true
  },
  "flex-drivers": {
    "group": "Drivers",
    "summary": "Instrument drivers, organized by vendor (including LevyLab)",
    "drivers": [
      "srs.sr7270",
      "colby.pdl",
      "rotrics.dexarm",
      "levylab.lockin",
      "levylab.krohn_hite",
      "levylab.transport_server",
      "levylab.ppms",
      "levylab.opticool",
      "levylab.cryostation",
      "levylab.oxford1820",
      "levylab.oxford_vrm",
      "levylab.tc_cf",
      "levylab.tc_mnk",
      "levylab.aerotech"
    ],
    "registries": {
      "drivers": "flex_drivers:CATALOG"
    }
  },
  "flex-datatypes": {
    "group": "Integrations",
    "summary": "HDF5 and TDMS (LabVIEW-compatible) data file writers",
    "default": true,
    "provides": {
      "writer": ["hdf5", "tdms"]
    },
    "registries": {
      "writer": "flex_datatypes:WRITERS"
    }
  },
  "flex-nextcloud": {
    "group": "Integrations",
    "summary": "Nextcloud storage backend (WebDAV upload)",
    "provides": {
      "storage": ["nextcloud"]
    },
    "registries": {
      "storage": "flex_nextcloud:STORAGE"
    }
  },
  "flex-asana": {
    "group": "Integrations",
    "summary": "Asana project-tracking hooks (via n8n webhooks)"
  }
}
